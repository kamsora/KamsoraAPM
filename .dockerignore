# Keep the Docker build context clean. Without this, a developer's locally
# built obj/ (with host-specific project.assets.json) gets COPYed into the
# image, and `dotnet publish --no-restore` then fails reading that stale cache
# (MSB4018 in ResolvePackageAssets). The Dockerfiles restore inside the image,
# so none of these are needed in the context.

# .NET build outputs
**/bin/
**/obj/
**/out/
artifacts/

# Node / SPA build outputs (regenerated by npm ci + npm run build)
**/node_modules/
**/dist/

# Test + coverage output
**/TestResults/
**/coverage/

# VCS + IDE
.git/
.gitignore
.vs/
.vscode/
.idea/
**/*.user

# Local logs
logs/
**/*.log

# Docker metadata (not needed inside the image)
**/.dockerignore
