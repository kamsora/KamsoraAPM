# Copy this file to `.env` next to docker-compose.yml and REPLACE EVERY VALUE.
# DO NOT commit `.env`.
#
#   cp deploy/docker/.env.example deploy/docker/.env
#
# The values below are the repository's well-known development defaults.
# The Collector and Dashboard.Api detect them at startup and REFUSE TO RUN
# in Production until they are replaced — so the stack will not come up
# until you edit this file.

# ---- Container image version ---------------------------------------------------
KAMSORA_APM_VERSION=edge

# ---- Database credentials -------------------------------------------------------
# Postgres only applies the password on a FRESH data volume. If you change it
# later: docker volume rm kamsora-apm-postgres-data (destroys data).
POSTGRES_PASSWORD=kamsora_dev_only_change_me
CLICKHOUSE_PASSWORD=kamsora_dev_only_change_me

# ---- Dashboard JWT signing key ----------------------------------------------------
# 32+ byte random base64 string. Generate one with:
#   openssl rand -base64 48
KAMSORA_APM_JWT_SIGNING_KEY=ZGV2LW9ubHktcGxlYXNlLXJlcGxhY2UtdGhpcy13aXRoLXJhbmRvbS00OC1ieXRlLWtleS1ub3c

# ---- First-run admin account -------------------------------------------------------
# Created automatically on first start, along with a default Agent API key
# (printed once in the dashboard-api container logs).
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe!2026

# ---- Tenant branding (optional) ------------------------------------------------------
SEED_TENANT_NAME=My Company
SEED_TENANT_SLUG=my-company
