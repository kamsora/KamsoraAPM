# KamsoraAPM production environment.
#
# 1. Copy this file:  cp .env.production.example .env.production
# 2. Run the bootstrap script (auto-generates strong secrets):
#       ./bootstrap.sh
# 3. Manually set the DOMAIN / EMAIL / ADMIN values below.
# 4. Bring the stack up:
#       docker compose --env-file .env.production -f docker-compose.production.yml up -d
#
# WARNING: never commit .env.production to git.

# ---------- Public hostname + TLS --------------------------------------------
# Domain that resolves (DNS A-record) to this server's public IP.
# Used by Caddy for the TLS cert and embedded into the JWT issuer claim.
#
# For BYO-cert mode (docker-compose.byo-cert.yml): this MUST be covered by
# your wildcard cert. Example: cert for *.example.com â†’ KAMSORA_DOMAIN=apm.example.com
KAMSORA_DOMAIN=apm.example.com
# Email Let's Encrypt sends cert-expiry warnings to.
# Only used in Let's Encrypt mode (docker-compose.production.yml on its own).
# In BYO-cert mode (with docker-compose.byo-cert.yml) this is ignored.
KAMSORA_ACME_EMAIL=ops@example.com

# ---------- First-run seeded tenant + platform admin -------------------------
# On first start (DB empty) the Dashboard.Api seeds this tenant + owner user.
# The admin password is the one you'll log in with first. Change it immediately.
SEED_TENANT_NAME=Kamsora
SEED_TENANT_SLUG=kamsora
SEED_ADMIN_EMAIL=admin@example.com
# Generated by bootstrap.sh â€” replace if you want a chosen value, otherwise the
# script picks a strong random one and prints it on first boot.
SEED_ADMIN_PASSWORD=

# ---------- Internal database credentials (auto-generated) -------------------
# DO NOT change manually. bootstrap.sh writes strong random values here.
POSTGRES_PASSWORD=
CLICKHOUSE_PASSWORD=

# ---------- Dashboard.Api JWT signing key (auto-generated) -------------------
# 64-byte random base64 string. Rotating this invalidates every live session.
JWT_SIGNING_KEY=

# ---------- Tunable knobs ----------------------------------------------------
# Container image tag the compose pulls. "latest" is fine for a single-host
# deploy; for traceability pin to a git commit short-sha or version.
KAMSORA_IMAGE_TAG=latest

# Collector bounded ingestion queue. Increase if you see drops under burst.
COLLECTOR_QUEUE_CAPACITY=100000
COLLECTOR_BATCH_SIZE=5000

# Backup retention in days. Older backups are pruned by the backup sidecar.
BACKUP_RETENTION_DAYS=7
# Cron expression (UTC) for daily backups. Default 03:00 UTC.
BACKUP_CRON_SCHEDULE=0 3 * * *
