# DUMMY env file for `docker compose config` validation ONLY.
# Never use these values on a real server. Bootstrap.sh generates real values
# into .env.production.
#
# Usage:
#   docker compose --env-file deploy/production/.env.validate \
#       -f deploy/production/docker-compose.production.yml \
#       -f deploy/production/docker-compose.byo-cert.yml \
#       config

KAMSORA_DOMAIN=apm.example.com
KAMSORA_ACME_EMAIL=ops@example.com
POSTGRES_PASSWORD=validation-dummy-not-real
CLICKHOUSE_PASSWORD=validation-dummy-not-real
JWT_SIGNING_KEY=validation-dummy-must-be-at-least-32-bytes-long-padding-padding
SEED_TENANT_NAME=Test
SEED_TENANT_SLUG=test
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=validation-dummy
KAMSORA_IMAGE_TAG=latest
COLLECTOR_QUEUE_CAPACITY=100000
COLLECTOR_BATCH_SIZE=5000
BACKUP_RETENTION_DAYS=7
BACKUP_CRON_SCHEDULE=0 3 * * *
